{
  "ConnectionStrings": {
    "Default": "Host=localhost;Port=5432;Database=identity_db;Username=baseforge;Password=change_me"
  },
  "Auth": {
    "Issuer": "http://localhost:5090/",
    "SigningCertificatePath": "",
    "SigningCertificatePassword": "",
    "Scopes": [
      { "Name": "api", "Resource": "baseforge-api" }
    ],
    "Clients": [
      {
        "ClientId": "spa-client",
        "Public": true,
        "Grants": [ "password", "refresh_token" ],
        "Scopes": [ "api" ]
      },
      {
        "ClientId": "service-worker",
        "Secret": "service-secret",
        "Public": false,
        "Grants": [ "client_credentials" ],
        "Scopes": [ "api" ]
      },
      {
        "ClientId": "web",
        "Public": true,
        "Grants": [ "authorization_code", "refresh_token" ],
        "Scopes": [ "api" ],
        "RedirectUris": [ "https://oauth.pstmn.io/v1/callback", "http://localhost:3000/callback" ]
      }
    ],
    "SeedAdmin": {
      "Email": "admin@baseforge.local",
      "Password": "Admin!2345"
    },
    "Providers": {
      "Google": { "ClientId": "", "ClientSecret": "" },
      "GitHub": { "ClientId": "", "ClientSecret": "" },
      "Microsoft": { "ClientId": "", "ClientSecret": "" },
      "Facebook": { "ClientId": "", "ClientSecret": "" }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
