@page
@model BaseForge.Identity.Pages.Account.LoginModel
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Giriş — BaseForge Identity</title>
    <style>
        body { font-family: system-ui, sans-serif; max-width: 360px; margin: 60px auto; padding: 0 16px; }
        h2 { margin-bottom: 4px; }
        input, button { width: 100%; padding: 10px; margin: 6px 0; box-sizing: border-box; border-radius: 6px; border: 1px solid #ccc; }
        button { background: #2563eb; color: #fff; border: 0; cursor: pointer; }
        .ext { background: #fff; color: #222; border: 1px solid #ccc; }
        .err { color: #c00; }
        hr { margin: 18px 0; border: 0; border-top: 1px solid #eee; }
    </style>
</head>
<body>
    <h2>Giriş</h2>
    <p style="color:#666;margin-top:0">BaseForge Identity</p>

    @if (Model.Error is not null)
    {
        <p class="err">@Model.Error</p>
    }

    <form method="post">
        <input type="hidden" name="returnUrl" value="@Model.ReturnUrl" />
        <input asp-for="Email" type="email" placeholder="E-posta" required />
        <input asp-for="Password" type="password" placeholder="Parola" required />
        <button type="submit">Giriş yap</button>
    </form>

    @if (Model.ExternalLogins.Count > 0)
    {
        <hr />
        <p style="color:#666">veya şununla giriş yap:</p>
        @foreach (var provider in Model.ExternalLogins)
        {
            <form method="post" asp-page-handler="External">
                <input type="hidden" name="provider" value="@provider.Name" />
                <input type="hidden" name="returnUrl" value="@Model.ReturnUrl" />
                <button class="ext" type="submit">@provider.DisplayName</button>
            </form>
        }
    }
</body>
</html>
