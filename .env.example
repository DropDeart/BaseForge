# BaseForge ortam değişkenleri örneği.
# Bu dosyayı .env olarak kopyalayın ve değerleri doldurun. .env git'e commit edilmez.

# PostgreSQL
POSTGRES_USER=baseforge
POSTGRES_PASSWORD=change_me
POSTGRES_DB=baseforge
POSTGRES_PORT=5432

# RabbitMQ
RABBITMQ_USER=baseforge
RABBITMQ_PASSWORD=change_me
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672

# JWT (merkezi Identity Service)
JWT_ISSUER=https://identity.baseforge.local
JWT_AUDIENCE=baseforge-services
JWT_SIGNING_KEY=change_me_to_a_long_random_secret
